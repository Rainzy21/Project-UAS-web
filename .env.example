# Copy this file to .env and fill in real values.
# cp .env.example .env
#
# SECURITY: Never commit .env or SUPABASE_SERVICE_ROLE_KEY to git.
# If the service role key is leaked, rotate it immediately in Supabase Dashboard → API.

# Supabase — Project Settings → API / JWT Keys
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-from-api-keys
SUPABASE_JWT_SECRET=your-jwt-secret-from-jwt-settings
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (required for production rate limiting)
REDIS_URL=redis://localhost:6379

# Environment: development | staging | production
ENVIRONMENT=development

# CORS — exact frontend origin (Render: https://your-app.onrender.com)
FRONTEND_URL=http://localhost:5500

# Render/reverse proxy — trust X-Forwarded-For (set to * on Render)
# TRUSTED_PROXY_IPS=*

# Optional — only for ./scripts/apply_supabase_schema.sh (Dashboard → Database → password)
# SUPABASE_DB_PASSWORD=your-database-password

# Supabase Auth — Google + Email
# Dashboard: https://supabase.com/dashboard/project/YOUR_PROJECT/auth/providers
#
# Email (required for sign-up / sign-in with password):
# 1. Authentication → Providers → Email → Enable
# 2. Enable "Confirm email" (recommended)
# 3. Authentication → URL Configuration → Redirect URLs (add all you use):
#    http://localhost:5500/auth-callback.html
#    http://localhost:5500/reset-password.html
#    (used for Google OAuth PKCE and email confirmation links)
# 4. Enable automatic account linking if available (same verified email → one user)
#
# Google (optional social login):
# 1. Authentication → Providers → Google → Enable
# 2. Create OAuth credentials at https://console.cloud.google.com/apis/credentials
#    - Application type: Web application
#    - Authorized redirect URI (exact):
#      https://YOUR_PROJECT.supabase.co/auth/v1/callback
# 3. Paste Google Client ID + Client Secret into Supabase Google provider
# 4. Use localhost only for dev — not 127.0.0.1 (breaks PKCE OAuth storage)

# External APIs
DEEPSEEK_API_KEY=your-deepseek-api-key
TMDB_API_KEY=your-tmdb-api-key
GEMINI_API_KEY=your-gemini-api-key

# Optional — error tracking (leave blank for local dev; no-op when unset)
# SENTRY_DSN=https://your-key@o123.ingest.sentry.io/456
